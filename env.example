# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Copy to .env and fill in your values
#
# All VITE_ variables are exposed to the browser bundle.
# Never commit real credentials to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application environment ──────────────────────────────────────────────────
# "development" uses the local mock database (mockData.js).
# Any other value (e.g. "production") hits real AWS services.
VITE_ENV=development

# ── AWS Region ───────────────────────────────────────────────────────────────
VITE_AWS_REGION=us-east-1

# ── Amazon Cognito ───────────────────────────────────────────────────────────
# User Pool ID  (format: us-east-1_XXXXXXXXX)
VITE_COGNITO_USER_POOL_ID=

# App Client ID  (no client secret – public SPA client)
VITE_COGNITO_CLIENT_ID=

# Cognito Identity Pool ID  (for unauthenticated DynamoDB access if needed)
# Format: us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_COGNITO_IDENTITY_POOL_ID=

# ── DynamoDB Table Names ──────────────────────────────────────────────────────
VITE_DYNAMO_USERS_TABLE=polla-users
VITE_DYNAMO_MATCHES_TABLE=polla-matches
VITE_DYNAMO_PREDICTIONS_TABLE=polla-predictions

# ── Optional: App URL (for Cognito callback URIs, CORS, etc.) ─────────────────
VITE_APP_URL=http://localhost:5173
